# Dedicated Podman network for hermes — NOT shared with zeroclaw or
# openclaw. Sibling containers on the default bridge cannot reach
# hermes via container IP. Combined with PublishPort=127.0.0.1:8642:
# 8642 in hermes.container, this gives:
#   - Host loopback (127.0.0.1) → hermes dashboard:    REACHABLE
#   - Host non-loopback / LAN  → hermes dashboard:    NOT REACHABLE (PublishPort restriction)
#   - Default-bridge containers → hermes container IP: NOT REACHABLE (different network)
#   - Hermes container          → host-loopback services: NOT REACHABLE (own namespace, not Network=host)
# This is the fleet-conservative default. Operators wanting LAN access
# add an SSH tunnel or reverse proxy with TLS+auth on top.

[Network]
NetworkName=hermes-isolated
Driver=bridge
DisableDNS=false
Internal=false
